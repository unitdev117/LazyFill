{
  "manifest_version": 3,
  "name": "LazyFill — AI Autofill Assistant",
  "version": "1.0.1",
  "description": "Intelligent AI-powered form autofill using Google AI. Create profiles, scan pages, and let AI fill your forms.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "frontend/dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "frontend/dist/content.js"
      ],
      "css": ["frontend/dist/assets/popup.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "frontend/dist/index.html",
    "default_icon": {
      "16": "frontend/dist/assets/icon16.png",
      "48": "frontend/dist/assets/icon48.png",
      "128": "frontend/dist/assets/icon128.png"
    }
  },
  "icons": {
    "16": "frontend/dist/assets/icon16.png",
    "48": "frontend/dist/assets/icon48.png",
    "128": "frontend/dist/assets/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "reset.html",
        "frontend/dist/assets/icon16.png",
        "frontend/dist/assets/icon48.png",
        "frontend/dist/assets/icon128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
